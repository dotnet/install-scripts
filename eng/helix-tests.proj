<!-- Custom Helix project that splits tests into one work item per test class for parallel execution. -->
<Project Sdk="Microsoft.DotNet.Helix.Sdk" DefaultTargets="Test">

  <PropertyGroup>
    <Language>msbuild</Language>
    <_Namespace>Install_Scripts.Test</_Namespace>
  </PropertyGroup>

  <!-- Windows work items (5 test classes) -->
  <ItemGroup Condition="'$(OS)' == 'Windows_NT'">
    <HelixWorkItem Include="AkaMsLinksTests">
      <PayloadDirectory>$(WorkItemDirectory)</PayloadDirectory>
      <Command>eng\helix-test-class.cmd $(_Namespace).AkaMsLinksTests</Command>
      <Timeout>$(WorkItemTimeout)</Timeout>
    </HelixWorkItem>
    <HelixWorkItem Include="GivenThatIWantToGetTheSdkLinksFromAScript">
      <PayloadDirectory>$(WorkItemDirectory)</PayloadDirectory>
      <Command>eng\helix-test-class.cmd $(_Namespace).GivenThatIWantToGetTheSdkLinksFromAScript</Command>
      <Timeout>$(WorkItemTimeout)</Timeout>
    </HelixWorkItem>
    <HelixWorkItem Include="GivenThatIWantToInstallDotnetFromAScript">
      <PayloadDirectory>$(WorkItemDirectory)</PayloadDirectory>
      <Command>eng\helix-test-class.cmd $(_Namespace).GivenThatIWantToInstallDotnetFromAScript</Command>
      <Timeout>$(WorkItemTimeout)</Timeout>
    </HelixWorkItem>
    <HelixWorkItem Include="GivenThatIWantToInstallDotnetRuntimeFromAScript">
      <PayloadDirectory>$(WorkItemDirectory)</PayloadDirectory>
      <Command>eng\helix-test-class.cmd $(_Namespace).GivenThatIWantToInstallDotnetRuntimeFromAScript</Command>
      <Timeout>$(WorkItemTimeout)</Timeout>
    </HelixWorkItem>
    <HelixWorkItem Include="WindowsTarExtractionTests">
      <PayloadDirectory>$(WorkItemDirectory)</PayloadDirectory>
      <Command>eng\helix-test-class.cmd $(_Namespace).WindowsTarExtractionTests</Command>
      <Timeout>$(WorkItemTimeout)</Timeout>
    </HelixWorkItem>
  </ItemGroup>

  <!-- Unix work items (5 test classes) -->
  <ItemGroup Condition="'$(OS)' != 'Windows_NT'">
    <HelixWorkItem Include="AkaMsLinksTests">
      <PayloadDirectory>$(WorkItemDirectory)</PayloadDirectory>
      <Command>eng/helix-test-class.sh $(_Namespace).AkaMsLinksTests</Command>
      <Timeout>$(WorkItemTimeout)</Timeout>
    </HelixWorkItem>
    <HelixWorkItem Include="BashTarExtractionTests">
      <PayloadDirectory>$(WorkItemDirectory)</PayloadDirectory>
      <Command>eng/helix-test-class.sh $(_Namespace).BashTarExtractionTests</Command>
      <Timeout>$(WorkItemTimeout)</Timeout>
    </HelixWorkItem>
    <HelixWorkItem Include="GivenThatIWantToGetTheSdkLinksFromAScript">
      <PayloadDirectory>$(WorkItemDirectory)</PayloadDirectory>
      <Command>eng/helix-test-class.sh $(_Namespace).GivenThatIWantToGetTheSdkLinksFromAScript</Command>
      <Timeout>$(WorkItemTimeout)</Timeout>
    </HelixWorkItem>
    <HelixWorkItem Include="GivenThatIWantToInstallDotnetFromAScript">
      <PayloadDirectory>$(WorkItemDirectory)</PayloadDirectory>
      <Command>eng/helix-test-class.sh $(_Namespace).GivenThatIWantToInstallDotnetFromAScript</Command>
      <Timeout>$(WorkItemTimeout)</Timeout>
    </HelixWorkItem>
    <HelixWorkItem Include="GivenThatIWantToInstallDotnetRuntimeFromAScript">
      <PayloadDirectory>$(WorkItemDirectory)</PayloadDirectory>
      <Command>eng/helix-test-class.sh $(_Namespace).GivenThatIWantToInstallDotnetRuntimeFromAScript</Command>
      <Timeout>$(WorkItemTimeout)</Timeout>
    </HelixWorkItem>
  </ItemGroup>

</Project>
